                                                                 2. DELETE STAFF ( MESSY CODE )
public class DeleteStaff {

    public void delete(int id) {

        try {
            ResultSet rs = database.executeReadQuery(
                    "SELECT * FROM staff WHERE staffId=" + id);

            if (rs.next()) {
                database.executeWriteQuery(
                        "DELETE FROM staff WHERE staffId=" + id);
            }

        } catch (Exception e) {
            System.out.println(e.getMessage());
        }
    }
}


                                                                    REFACTORED (ONLY ISP)
                                                                      🔹 Interface
interface StaffDB {
    boolean exists(int id);
    void delete(int id);
}




                                                                            🔹 Class Delete Staff ( Refactor) 
public class DeleteStaff {

    private StaffDB staffDB;

    public DeleteStaff(StaffDB staffDB) {
        this.staffDB = staffDB;
    }

    public void delete(int id) {

        if (staffDB.exists(id)) {
            staffDB.delete(id);
        }
    }
}





