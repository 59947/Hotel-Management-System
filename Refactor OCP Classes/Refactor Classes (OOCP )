        JComboBox<String> type =
                new JComboBox<>(
                        new String[]{
                                "Single",
                                "Double",
                                "Suite"
                        });

        JButton submit =
                createButton("Submit");

        submit.addActionListener(e -> {

            String query =
                    "INSERT INTO rooms(roomId,roomType)"
                            + " VALUES("
