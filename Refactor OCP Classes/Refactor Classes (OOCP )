package Customer;

import Common.BaseForm;
import Common.DatabaseService;

import javax.swing.*;
import java.awt.*;

public class AddCustomer extends BaseForm {

    public AddCustomer() {

        super("Add Customer",800,500);

        JPanel panel = new JPanel();

        JTextField idField = createTextField();
        JTextField nameField = createTextField();

        JButton submit =
                createButton("Submit");

        submit.addActionListener(e -> {

            String query =
                    "INSERT INTO customers VALUES("
                            + idField.getText()
                            + ",'"
                            + nameField.getText()
                            + "')";

            DatabaseService.executeInsert(query);

            JOptionPane.showMessageDialog(
                    this,
                    "Customer Added"
            );
        });

        panel.add(idField);
        panel.add(nameField);
        panel.add(submit);

        add(panel);

        setVisible(true);
    }
}

