                                                                                AddBooking

package Booking;

import Common.BaseForm;
import Common.DatabaseService;

import javax.swing.*;
import java.awt.*;
import java.sql.ResultSet;

public class AddBooking extends BaseForm {

    private JComboBox<Integer> roomBox;
    private JLabel priceLabel;

    public AddBooking() {

        super("Add Booking",800,500);

        JPanel panel = new JPanel();
        panel.setBackground(new Color(48,17,63));

        roomBox = new JComboBox<>();

        try {

            ResultSet rs =
                    DatabaseService.executeRead(
                            "SELECT * FROM rooms");

            while(rs.next()) {
                roomBox.addItem(rs.getInt("roomId"));
            }

        } catch(Exception e) {
            e.printStackTrace();
        }

        priceLabel = createLabel("0");

        JButton button =
                createButton("Calculate");

        button.addActionListener(e -> calculatePrice());

        panel.add(roomBox);
        panel.add(priceLabel);
        panel.add(button);

        add(panel);
        setVisible(true);
    }

    private void calculatePrice() {

        String roomType = "Single";

        RoomPricingStrategy strategy =
                RoomFactory.getRoom(roomType);

        double price = strategy.calculatePrice();

        priceLabel.setText("Rs. " + price);
    }
}


