                                                                                      RoomFactory

package Booking;

public class RoomFactory {

    public static RoomPricingStrategy getRoom(String type) {

        switch (type) {

            case "Single":
                return new SingleRoom();

            case "Double":
                return new DoubleRoom();

            case "Suite":
                return new SuiteRoom();

            default:
                throw new IllegalArgumentException("Invalid Room Type");
        }
    }
}

