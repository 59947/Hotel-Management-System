package Discount;

import javax.swing.*;
        import java.util.Date;

public class DiscountSelector {

    public static DiscountStrategy selectDiscount(JFrame parent, Date checkInDate) {
        String[] options = {
                "Loyalty Points Only",
                "Long Stay Discount (7+ nights: 10%, 14+ nights: 15%)",
                "Seasonal Discount (20% off in off-peak months)"
        };

        int choice = JOptionPane.showOptionDialog(
                parent,
                "Select Discount Type for This Booking:",
                "Discount Selection",
                JOptionPane.DEFAULT_OPTION,
                JOptionPane.QUESTION_MESSAGE,
                null, options, options[0]
        );

        switch (choice) {
            case 1:  return new LongStayDiscount();
            case 2:  return new SeasonalDiscount(checkInDate);
            default: return new LoyaltyDiscount();
        }
    }

    public static double applyAndConfirm(DiscountStrategy strategy, double originalPrice,
                                         int loyaltyPoints, long durationDays, JFrame parent) {
        double finalPrice = strategy.applyDiscount(originalPrice, loyaltyPoints, durationDays);
        JOptionPane.showMessageDialog(parent,
                "Discount: " + strategy.getDiscountName() + "\n"
                        + "Original: Rs. " + String.format("%.2f", originalPrice) + "\n"
                        + "Final:    Rs. " + String.format("%.2f", finalPrice),
                "Discount Applied", JOptionPane.INFORMATION_MESSAGE);
        return finalPrice;
    }
}
